{
  "name": "tao-sub",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "description": "Desktop app for building videos from scene images and SRT timing",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "dist:win": "yarn build && electron-builder --win --x64",
    "dist:mac": "yarn build && electron-builder --mac",
    "release": "release-it"
  },
  "build": {
    "appId": "com.tao-sub.video-builder",
    "productName": "Video Builder",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "dist-electron/**/*"],
    "extraResources": [
      { "from": "node_modules/ffmpeg-static", "to": "ffmpeg-static", "filter": ["**/*"] }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "mac": {
      "target": "dmg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "antd": "^6.1.0",
    "dayjs": "^1.11.21",
    "electron-store": "^11.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-window": "^2.2.7",
    "sharp": "^0.35.2",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.0",
    "electron": "^39.2.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.5.0",
    "release-it": "^17.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.0",
    "vite": "^7.2.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
