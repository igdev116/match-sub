{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "requireCleanWorkingDir": false
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:init": ["echo 'Starting release...'"],
    "after:bump": ["echo 'Version bumped to ${version}'"],
    "after:release": ["echo 'Released v${version}! GitHub Actions will build the .exe'"]
  }
}
